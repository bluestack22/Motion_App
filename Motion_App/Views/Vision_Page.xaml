<Page x:Class="Motion_App.View.Vision_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 

      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Vision_Window">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="240"/>
        </Grid.RowDefinitions>

        <!-- Images area -->
        <Grid Grid.Row="0" Margin="10,8,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Camera" Margin="6" Grid.Column="0">
                <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                    <Image x:Name="ImgBefore" Stretch="Uniform"
                           Source="{Binding CameraFeed}"/>
                </Border>
            </GroupBox>

            <GroupBox Header="Handler" Margin="6,6,6,6" Grid.Column="1">
                <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                    <Image x:Name="ImgAfter" Stretch="Uniform" Margin="0,0,0,11"
                           Source="{Binding ProcessedFeed}"/>
                </Border>
            </GroupBox>
        </Grid>

        <!-- Mode toggle -->


        <!-- Controls area -->
        <Grid Grid.Row="2" Margin="10,10,10,10" MinHeight="220">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Mode buttons placed on top border of controls -->
            <Border Grid.ColumnSpan="2"
                    Panel.ZIndex="20"
                    Background="LightSeaGreen"
                    CornerRadius="8"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="24,-16,0,0"
                    Padding="6,0">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="BtnOpenCVMode"
                                  Content="OpenCV"
                                  IsChecked="True"
                                  Click="Mode_Checked"
                                  Style="{DynamicResource AppToggleButtonStyle}"
                                  Padding="12,6"
                                  Command="{Binding OpenCVModeCommand}"/>
                    <ToggleButton x:Name="BtnAIMode"
                                  Content="AI-Mode"
                                  Click="Mode_Checked"
                                  Style="{DynamicResource AppToggleButtonStyle}"
                                  Padding="12,6"
                                  Command="{Binding AIModeCommand}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="0" Margin="6,0,6,6" Background="LightCyan" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="8">
                <Grid>
                    <Grid x:Name="OpenCV_LeftPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,6,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="3*"/>
                                <RowDefinition/>
                                <RowDefinition Height="2*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{DynamicResource AppButtonStyle}" Content="Capture" Width="80" Height="30" Margin="3,3,3,3" Grid.RowSpan="3"
                                    Command="{Binding CaptureCommand}"/>
                            <Button Grid.Column="1" Style="{DynamicResource AppButtonStyle}" Content="Save" Width="80" Height="30" Margin="3,3,3,3" Grid.RowSpan="3" 
                                    Command="{Binding SaveCommand}"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,4,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>

                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{DynamicResource AppButtonStyle}" Content="Blur" Width="80" Height="30" 
                                    Command="{Binding BlurViewCommand}"/>
                            <Button Grid.Column="1" Style="{DynamicResource AppButtonStyle}" Content="Edges" Width="80" Height="30" 
                                    Command="{Binding EdgesViewCommand}"/>
                            <Button Grid.Column="2" Style="{DynamicResource AppButtonStyle}" Content="Threshold" Width="80" Height="30" 
                                    Command="{Binding ThresholdViewCommand}"/>
                        </Grid>
                    </Grid>

                    <Grid x:Name="AI_LeftPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,6,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{DynamicResource AppButtonStyle}" Content="Capture" Width="80" Height="30" 
                                    Command="{Binding CaptureCommand}"/>
                            <Button Grid.Column="1" Style="{DynamicResource AppButtonStyle}" Content="Save" Width="80" Height="30" 
                                    Command="{Binding SaveCommand}"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{DynamicResource AppButtonStyle}" Content="Prev" Width="80" Height="30"
                                    Command="{Binding PrevCommand}"/>
                            <Button Grid.Column="1" Style="{DynamicResource AppButtonStyle}" Content="Next"  Width="80" Height="30"
                                    Command="{Binding NextCommand}"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,6,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Save as:" Margin="3,0,6,0"/>
                            <ComboBox Grid.Column="1" Width="100" 
                                      ItemsSource="{Binding SaveOptions}"
                                      SelectedItem="{Binding SelectedSaveOption, Mode=TwoWay}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="6,0,6,6" Background="LightCyan" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="8">
                <Grid>
                    <StackPanel x:Name="OpenCV_RightPanel" Orientation="Vertical" Visibility="Visible">
                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,6">Turning / Filters</TextBlock>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Style="{DynamicResource AppFieldLabelStyle}" 
                                       Text="Threshold:"/>
                            <Slider Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="255"
                                    Value="{Binding Threshold,Mode=TwoWay}" 
                                    TickFrequency="1"
                                    IsSnapToTickEnabled ="True"/>
                            <TextBox Grid.Column="2" 
                                     Margin="6,0,6,2" 
                                     Text="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     />
                        </Grid>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Blur:"/>
                            <Slider Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="50"
                                    Value="{Binding Blur, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" 
                                     Margin="6,0,6,0" 
                                     Text="{Binding Blur, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Canny Low:"/>
                            <Slider Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="255"
                                    Value="{Binding CannyLow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" 
                                     Margin="6,0,6,0"
                                     Text="{Binding CannyLow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Canny High:"/>
                            <Slider Grid.Column="1" 
                                    Minimum="0" 
                                    Maximum="255"
                                    Value="{Binding CannyHigh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" 
                                     Margin="6,0,6,0"
                                     Text="{Binding CannyHigh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Kernel:"/>
                            <ComboBox Grid.Column="1"
                                ItemsSource="{Binding KernelSizes}"
                                SelectedItem="{Binding SelectedKernel, Mode=TwoWay}">
                            </ComboBox>
                            <Grid Grid.Column="2" Margin="12,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Area:"/>
                                <TextBox Grid.Column="1" 
                                         Text="{Binding Area, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Grid>

                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center">Layer:</TextBlock>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Layer}"
                                      SelectedItem="{Binding SelectedLayer, Mode=TwoWay}">
                            </ComboBox>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="AI_RightPanel" Visibility="Collapsed" Margin="0,6">
                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,6">AI Parameters</TextBlock>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Confidence:"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding ConfidenceThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" Width="50" Margin="6,0,0,0" Text="{Binding ConfidenceThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{DynamicResource AppFieldLabelStyle}" Text="Box Match:"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding NmsThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="2" Width="50" Margin="6,0,0,0" Text="{Binding NmsThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged ,StringFormat=F1}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Page>
