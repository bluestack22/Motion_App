<Window x:Class="Motion_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Motion_App"
        xmlns:view="clr-namespace:Motion_App.View"
        xmlns:viewmodels="clr-namespace:Motion_App.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1200">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:VisionModel}">
            <view:Vision_Page />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingModel}">
            <view:Setting_Page />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:MotorModel}">
            <view:Motor_Page />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:TraceModel}">
            <view:Trace_Page />
        </DataTemplate>
    </Window.Resources>
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Top task bar with tabs -->
        <Grid Grid.Row="0" Background="#F5F5F5">
            <Border Background="White" BorderBrush="DarkSlateGray" BorderThickness="1" CornerRadius="5"/>
            <StackPanel x:Name="TopTabPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0" Height="42">
                <ToggleButton x:Name="TopTabMain" Content="Main" Padding="12,6" IsChecked="True" Style="{DynamicResource AppToggleButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Main"/>
                <ToggleButton x:Name="TopTabVision" Content="Vision" Padding="12,6" Style="{DynamicResource AppToggleButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Vision"/>
                <ToggleButton x:Name="TopTabMotor" Content="Motor" Padding="12,6" Style="{DynamicResource AppToggleButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Motor"/>
                <ToggleButton x:Name="TopTabTrace" Content="Trace" Padding="12,6" Style="{DynamicResource AppToggleButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Trace"/>
                <ToggleButton x:Name="TopTabSetting" Content="Setting" Padding="12,6" Style="{DynamicResource AppToggleButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Setting"/>
            </StackPanel>
        </Grid>

        <!-- Main content area (shown when TopTabMain is selected) -->
        <Grid x:Name="MainContent" Grid.Row="1" Background="White" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="139*"/>
                <ColumnDefinition Width="27*"/>
                <ColumnDefinition Width="1022*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Welcome to Main Window" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333" FontSize="18" Grid.Column="4" Margin="317,0,0,0"/>
        </Grid>

        <!-- Main content ContentControl (bound to CurrentViewModel) -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" />

        <!-- Bottom control area removed -->
    </Grid>
</Window>
